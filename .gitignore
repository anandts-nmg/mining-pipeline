# Generated registers / logs (regenerate from the pipeline)
*.xlsx
*.xls
*.xlsm
*.ods
# Word sources are ignored by default. The reviewed methodology snapshot under
# docs/methodology is an exact path-and-hash exception enforced by repository policy.
*.docx
!docs/methodology/
!docs/methodology/**/
!docs/methodology/**/*.docx
*.doc
*.docm
*.odt
*.ppt
*.pptm
*.pptx
SHA-256_Checksum_Register.csv
!config/*.csv          # keep the curated input register under version control

