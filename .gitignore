# ---- Project data & generated outputs (NEVER commit raw data or deliverables) ----
# Keep this denylist aligned with src/buduunkhad/repository_policy.py, which is
# the authoritative streamed policy check exercised by tests and CI.
data/
raw/
outputs/
control/
runs/
runtime/
log/
logs/
cache/
caches/
artifacts/
*.gpkg
*.tif
*.tiff
*.hdf
*.h5
*.hdf5
