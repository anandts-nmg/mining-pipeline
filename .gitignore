# Intentional synthetic exceptions must be exact paths pinned by the reusable
# repository policy; no fixture directory is exempted wholesale.

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

